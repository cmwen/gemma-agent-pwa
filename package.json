{
  "name": "gemma-agent-pwa",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.15.1",
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "biome check .",
    "format": "biome format --write .",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "dev": "tsx scripts/dev.ts",
    "dev:api": "pnpm --filter @gemma-agent-pwa/api dev",
    "dev:web": "pnpm --filter @gemma-agent-pwa/web dev"
  },
  "devDependencies": {
    "@ag-ui/core": "^0.0.53",
    "@ag-ui/encoder": "^0.0.53",
    "@biomejs/biome": "^2.4.15",
    "@playwright/test": "^1.60.0",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.9.1",
    "concurrently": "^9.2.1",
    "jsdom": "^29.1.1",
    "tsup": "^8.5.1",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
