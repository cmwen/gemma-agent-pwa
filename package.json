{
  "name": "gemma-agent-pwa",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.15.1",
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "biome check .",
    "format": "biome format --write .",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "dev": "tsx scripts/dev.ts",
    "dev:api": "pnpm --filter @gemma-agent-pwa/api dev",
    "dev:web": "pnpm --filter @gemma-agent-pwa/web dev"
  },
  "devDependencies": {
    "@ag-ui/core": "^0.0.53",
    "@ag-ui/encoder": "^0.0.53",
    "@biomejs/biome": "latest",
    "@playwright/test": "^1.54.2",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "latest",
    "concurrently": "latest",
    "jsdom": "^29.0.1",
    "tsup": "latest",
    "tsx": "latest",
    "typescript": "latest",
    "vitest": "latest"
  }
}
